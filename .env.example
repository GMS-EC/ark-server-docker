# Required - User and Group IDs for file permissions
PUID=1000
PGID=1000

# Server Configuration
SESSION_NAME=ARK Server
SERVER_PASSWORD=
ADMIN_PASSWORD=adminpass
MAX_PLAYERS=10
WORLD=TheIsland

# Ports
SERVER_PORT=7777
QUERY_PORT=27015
RCON_PORT=27020

# Basic Server Mode
SERVER_PVE=false
BATTLEEYE=false
RCON_ENABLED=true

# Cluster Settings (leave empty if not using cluster)
CLUSTER_ID=
CLUSTER_DIR_OVERRIDE=

# Mods (comma-separated mod IDs, e.g., 731604991,893735676)
MOD_IDS=

# Additional server arguments (optional)
# Add any custom flags here, e.g.:
# ADDITIONAL_ARGS=-automanagedmods -ServerHardcore -ForceAllowCaveFlyers -DisableStructureDecayPvE
ADDITIONAL_ARGS=

# Server branch/beta (public, preaquatica, etc.)
BETA=public

# Update Settings
UPDATE_ON_START=true

# --- Automatic Backup Settings ---
# Enable automatic scheduled backups (default: true)
BACKUP_ENABLED=true
# Interval between backups, in hours (default: 6)
BACKUP_INTERVAL_HOURS=6
# Directory where backups are stored (default: /home/steam/ark-backups)
# Mount this path as a volume in docker-compose.yml to persist backups
BACKUP_DIR=/home/steam/ark-backups
# Max number of recent backup files to keep before rotating out older backups.
# Leave empty or set to 0 to disable rotation (keep all backups).
BACKUP_MAX_COUNT=

# --- Discord Notifications ---
# Webhook URL for server status, update, and backup notifications
DISCORD_WEBHOOK_URL=
# Language for Discord notification messages ("es" or "en", default: es)
DISCORD_LANGUAGE=es

# --- Scheduled Restarts ---
# Interval in hours for automatic server restarts with in-game warnings (0 = disabled)
AUTO_RESTART_HOURS=0

# --- Automatic Power Schedule (Process On/Off) ---
# Enable/disable automatic server process start/stop schedule (default: false)
SCHEDULE_ENABLED=false
# Server start time in 24h format HH:MM (e.g., "20:00")
SCHEDULE_START=20:00
# Server stop time in 24h format HH:MM (e.g., "00:00")
SCHEDULE_STOP=00:00
# Container timezone (default: UTC). Affects how SCHEDULE_START and SCHEDULE_STOP are evaluated.
# Example: America/Guayaquil, America/New_York, Europe/Madrid, Etc/UTC
TZ=UTC
# In-game warning advance notice in minutes before shutting down (default: 10)
SCHEDULE_WARN_MINUTES=10


# --- Server Rate Multipliers ---
# Leave empty to use game defaults (1.0)
XP_MULTIPLIER=
TAME_SPEED_MULTIPLIER=
HARVEST_AMOUNT_MULTIPLIER=
HATCH_SPEED_MULTIPLIER=
MATURATION_SPEED_MULTIPLIER=
MATING_INTERVAL_MULTIPLIER=
CRAFT_SPEED_MULTIPLIER=
